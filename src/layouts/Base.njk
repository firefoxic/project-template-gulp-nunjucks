{%- from "../components/Header/index.njk" import Header with context -%}
{%- from "../components/Footer/index.njk" import Footer with context -%}
{%- from "../components/Logo/index.njk" import Logo with context -%}
{%- from "../components/Navigation/index.njk" import Navigation with context -%}
{%- from "../components/Copyright/index.njk" import Copyright with context -%}
{%- from "../shared/fonts/index.njk" import fonts with context -%}
{%- from "../styles/index.njk" import styles with context -%}
{%- from "../scripts/index.njk" import scripts with context -%}

<!DOCTYPE html>
<html lang="{{ page.lang or "en" }}">

	<head>
		<meta charset="UTF-8">
		<title>{{ page.title }} — {{ project.name }}</title>
		<meta name="viewport" content="width=device-width,initial-scale=1">
		<meta name="color-scheme" content="light dark">
		{{ fonts() }}
		{{ styles() }}
		<link rel="icon" href="{{ project.root }}/favicon.ico" sizes="32x32">
		<link rel="icon" href="{{ project.root }}/favicon.svg" type="image/svg+xml">
		<link rel="manifest" href="{{ project.root }}/manifest.webmanifest">
		{{ scripts() }}
	</head>

	<body class="page">

		{% call Header("page__header") %}
		<div class="page__centerer header__container">
			{{ Logo("header__logo") }}
			{{ Navigation("header__navigation") }}
		</div>
		{% endcall %}

		<main class="page__content">
			{% block Content %}{% endblock %}
		</main>

		{% call Footer("page__footer") %}
		<div class="page__centerer footer__container">
			{{ Logo("footer__logo") }}
			{{ Copyright("footer__copyright") }}
		</div>
		{% endcall %}

	</body>

</html>
