{% extends "./layouts/Base.njk" %}

{% from "./components/Picture/index.njk" import Picture with context %}

{% set page = {
	title: "Main page",
	link: project.root ~ "/"
} %}

{% block Content %}
	<div class="page__centerer">
		<h1 class="heading heading--size_huge">{{ page.title }}</h1>

		<p>
		{{ Picture("eclipse", { class: "image", loading: "lazy", alt: "Eclipse" }) }}
		</p>
	</div>
{% endblock Content %}
